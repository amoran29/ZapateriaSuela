@page "/clientes"

@using Microsoft.EntityFrameworkCore
@using ZapateriaSuela.Data
@using ZapateriaSuela.Models

@inject AppDbContext Context

<h1 class="title">CLIENTES</h1>

<hr />

<div class="container">

    <div class="form-box">

        <EditForm Model="cliente" OnValidSubmit="GuardarCliente">

            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-group">
                <label>Nombre</label>
                <InputText class="input" @bind-Value="cliente.Nombre" />
            </div>

            <div class="form-group">
                <label>Teléfono</label>
                <InputText class="input" @bind-Value="cliente.Telefono" />
            </div>

            <div class="form-group">
                <label>Email</label>
                <InputText class="input" @bind-Value="cliente.Email" />
            </div>

            <button class="btn-save">
                Guardar Cliente
            </button>

        </EditForm>

    </div>

</div>

<hr />

@if (clientes == null)
{
    <p>Cargando clientes...</p>
}
else
{
    <div class="table-container">

        <table class="table">

            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Teléfono</th>
                    <th>Email</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var c in clientes)
                {
                    <tr>
                        <td>@c.Nombre</td>
                        <td>@c.Telefono</td>
                        <td>@c.Email</td>
                        <td class="actions">

                            <button class="btn-edit"
                                    @onclick="() => EditarCliente(c)">
                                Editar
                            </button>

                            <button class="btn-delete"
                                    @onclick="() => EliminarCliente(c.Id)">
                                Eliminar
                            </button>

                        </td>
                    </tr>
                }

            </tbody>

        </table>

    </div>
}
<style>
    body {
        background: #121212;
        color: #fff;
    }

    .title {
        text-align: center;
        margin-bottom: 20px;
        color: #fff;
    }

    .container {
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .form-box {
        width: 100%;
        max-width: 500px;
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.6);
        background: #1e1e1e;
        color: #fff;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        margin-bottom: 15px;
    }

    label {
        margin-bottom: 5px;
        font-weight: bold;
        color: #e0e0e0;
    }

    .input {
        padding: 10px;
        border-radius: 6px;
        border: 1px solid #333;
        background: #2a2a2a;
        color: #fff;
    }

        .input:focus {
            outline: none;
            border-color: #007bff;
            box-shadow: 0 0 5px #007bff;
        }

    .btn-save {
        width: 100%;
        padding: 10px;
        background: #000;
        color: white;
        border: 1px solid #444;
        border-radius: 6px;
        cursor: pointer;
    }

        .btn-save:hover {
            background: #222;
        }

    .table-container {
        display: flex;
        justify-content: center;
    }

    .table {
        width: 90%;
        max-width: 900px;
        border-collapse: collapse;
        background: #1e1e1e;
        box-shadow: 0 4px 20px rgba(0,0,0,0.6);
        border-radius: 10px;
        overflow: hidden;
        color: #fff;
    }

        .table th, .table td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #333;
        }

        .table th {
            background: #111;
            color: #fff;
        }

        .table tr:hover {
            background: #2a2a2a;
        }

    .actions {
        display: flex;
        gap: 10px;
    }

    .btn-edit {
        padding: 6px 10px;
        border: none;
        background: #444;
        color: white;
        border-radius: 5px;
        cursor: pointer;
    }

    .btn-delete {
        padding: 6px 10px;
        border: none;
        background: #000;
        color: white;
        border: 1px solid #444;
        border-radius: 5px;
        cursor: pointer;
    }

    .btn-edit:hover {
        background: #666;
    }

    .btn-delete:hover {
        background: #222;
    }
</style>

@code {
    Cliente cliente = new();
    List<Cliente>? clientes;

    protected override async Task OnInitializedAsync()
    {
        await CargarClientes();
    }

    private async Task CargarClientes()
    {
        clientes = await Context.Clientes.ToListAsync();
    }

    private async Task GuardarCliente()
    {
        if (cliente.Id == 0)
        {
            Context.Clientes.Add(cliente);
        }
        else
        {
            var clienteDb = await Context.Clientes.FindAsync(cliente.Id);

            if (clienteDb != null)
            {
                clienteDb.Nombre = cliente.Nombre;
                clienteDb.Telefono = cliente.Telefono;
                clienteDb.Email = cliente.Email;
            }
        }

        await Context.SaveChangesAsync();

        cliente = new();
        await CargarClientes();
    }

    private void EditarCliente(Cliente c)
    {
        cliente = new Cliente
        {
            Id = c.Id,
            Nombre = c.Nombre,
            Telefono = c.Telefono,
            Email = c.Email
        };
    }

    private async Task EliminarCliente(int id)
    {
        var clienteEliminar = await Context.Clientes.FindAsync(id);

        if (clienteEliminar != null)
        {
            Context.Clientes.Remove(clienteEliminar);
            await Context.SaveChangesAsync();
            await CargarClientes();
        }
    }
}