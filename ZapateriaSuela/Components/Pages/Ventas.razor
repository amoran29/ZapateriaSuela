@page "/ventas"

@using Microsoft.EntityFrameworkCore
@using ZapateriaSuela.Data
@using ZapateriaSuela.Models

@inject AppDbContext Context

<h1>🛒 REGISTRO DE VENTAS</h1>

<hr />

<div class="card p-4 shadow-sm">

    <div class="mb-3">
        <label class="form-label">Cliente</label>

        <select class="form-select" @bind="venta.ClienteId">
            <option value="0">Selecciona un cliente</option>

            @foreach (var cliente in clientes)
            {
                <option value="@cliente.Id">@cliente.Nombre</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Producto API ID</label>
        <InputNumber class="form-control" @bind-Value="productoApiId" />
    </div>

    <div class="mb-3">
        <label class="form-label">Cantidad</label>
        <InputNumber class="form-control" @bind-Value="cantidad" />
    </div>

    <div class="mb-3">
        <label class="form-label">Precio</label>
        <InputNumber class="form-control" @bind-Value="precio" />
    </div>

    <button class="btn btn-success" @onclick="GuardarVenta">
        Registrar Venta
    </button>

</div>

<hr />

<h3>Ventas</h3>

@if (ventas == null)
{
    <p>Cargando ventas...</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Cliente</th>
                <th>Fecha</th>
                <th>Total</th>
                <th>Estado</th>
                <th>Acción</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var v in ventas)
            {
                <tr>
                    <td>@v.Cliente?.Nombre</td>
                    <td>@v.Fecha.ToShortDateString()</td>
                    <td>$@v.Total</td>
                    <td>@v.Estado</td>

                    <td>
                        <button class="btn btn-sm btn-warning"
                                @onclick="() => CambiarEstadoVenta(v.Id)">
                            Cambiar estado
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<hr />

<h3>Detalle Ventas</h3>

@if (detalles == null)
{
    <p>Cargando detalles...</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Venta ID</th>
                <th>Producto API ID</th>
                <th>Cantidad</th>
                <th>Precio</th>
                <th>Subtotal</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var d in detalles)
            {
                <tr>
                    <td>@d.VentaId</td>
                    <td>@d.ProductoApiId</td>
                    <td>@d.Cantidad</td>
                    <td>$@d.Precio</td>
                    <td>$@(d.Cantidad * d.Precio)</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {

    Venta venta = new()
    {
        Estado = "Completada"
    };

    List<Cliente> clientes = new();
    List<Venta>? ventas;
    List<DetalleVenta>? detalles;

    int productoApiId;
    int cantidad = 1;
    decimal precio;

    protected override async Task OnInitializedAsync()
    {
        clientes = await Context.Clientes.ToListAsync();
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        ventas = await Context.Ventas
            .Include(v => v.Cliente)
            .ToListAsync();

        detalles = await Context.DetalleVentas.ToListAsync();
    }

    private async Task GuardarVenta()
    {
        var nuevaVenta = new Venta
        {
            ClienteId = venta.ClienteId,
            Fecha = DateTime.Now,
            Estado = "Completada",
            Total = cantidad * precio
        };

        Context.Ventas.Add(nuevaVenta);
        await Context.SaveChangesAsync();

        var detalle = new DetalleVenta
        {
            VentaId = nuevaVenta.Id,
            ProductoApiId = productoApiId,
            Cantidad = cantidad,
            Precio = precio
        };

        Context.DetalleVentas.Add(detalle);
        await Context.SaveChangesAsync();

        productoApiId = 0;
        cantidad = 1;
        precio = 0;

        venta = new Venta();

        await CargarDatos();
    }

    private async Task CambiarEstadoVenta(int id)
    {
        var ventaDb = await Context.Ventas.FindAsync(id);

        if (ventaDb != null)
        {
            ventaDb.Estado =
                ventaDb.Estado == "Completada"
                    ? "Cancelada"
                    : "Completada";

            await Context.SaveChangesAsync();
            await CargarDatos();
        }
    }
}

        
