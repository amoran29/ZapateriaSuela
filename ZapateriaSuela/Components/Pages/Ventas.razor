@page "/ventas"

@using Microsoft.EntityFrameworkCore
@using ZapateriaSuela.Data
@using ZapateriaSuela.Models

@inject AppDbContext Context

<h1>🛒 REGISTRO DE VENTAS</h1>

<hr />

<div class="card p-4 shadow-sm">

    <div class="mb-3">

        <label class="form-label">
            Cliente
        </label>

        <select class="form-select"
                @bind="venta.ClienteId">

            <option value="0">
                Selecciona un cliente
            </option>

            @foreach (var cliente in clientes)
            {
                <option value="@cliente.Id">
                    @cliente.Nombre
                </option>
            }

        </select>

    </div>

    <div class="mb-3">

        <label class="form-label">
            Producto API ID
        </label>

        <InputNumber class="form-control"
                     @bind-Value="productoApiId" />

    </div>

    <div class="mb-3">

        <label class="form-label">
            Cantidad
        </label>

        <InputNumber class="form-control"
                     @bind-Value="cantidad" />

    </div>

    <div class="mb-3">

        <label class="form-label">
            Precio
        </label>

        <InputNumber class="form-control"
                     @bind-Value="precio" />

    </div>

    <button class="btn btn-success"
            @onclick="GuardarVenta">

        Registrar Venta

    </button>

</div>

<hr />

<h3>Historial</h3>

@if (ventas == null)
{
    <p>Cargando ventas...</p>
}
else
{
    <table class="table table-striped">

        <thead>

            <tr>
                <th>Cliente</th>
                <th>Fecha</th>
                <th>Total</th>
                <th>Estado</th>
            </tr>

        </thead>

        <tbody>

            @foreach (var v in ventas)
            {
                <tr>

                    <td>@v.Cliente?.Nombre</td>

                    <td>@v.Fecha.ToShortDateString()</td>

                    <td>$@v.Total</td>

                    <td>@v.Estado</td>

                </tr>
            }

        </tbody>

    </table>
}
<style>
    body {
        background: #121212;
        color: #fff;
    }

    h1, h3 {
        text-align: center;
        color: #fff;
        margin-bottom: 20px;
    }

    hr {
        border: 1px solid #333;
    }

    /* CONTENEDOR PRINCIPAL (FLEXBOX) */
    .card {
        max-width: 600px;
        margin: 0 auto;
        background: #1e1e1e;
        border-radius: 10px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.6);
        padding: 20px;
        color: #fff;
    }

    .mb-3 {
        display: flex;
        flex-direction: column;
        margin-bottom: 15px;
    }

    .form-label {
        margin-bottom: 5px;
        font-weight: bold;
        color: #e0e0e0;
    }

    .form-select,
    .form-control {
        padding: 10px;
        border-radius: 6px;
        border: 1px solid #333;
        background: #2a2a2a;
        color: #fff;
    }

        .form-select:focus,
        .form-control:focus {
            outline: none;
            border-color: #007bff;
            box-shadow: 0 0 5px #007bff;
        }

    .btn-success {
        width: 100%;
        padding: 10px;
        background: #000;
        color: #fff;
        border: 1px solid #444;
        border-radius: 6px;
        cursor: pointer;
        margin-top: 10px;
    }

        .btn-success:hover {
            background: #222;
        }

    /* TABLA */
    .table {
        width: 90%;
        max-width: 900px;
        margin: 0 auto;
        border-collapse: collapse;
        background: #fff;
        box-shadow: 0 4px 20px rgba(0,0,0,0.6);
        border-radius: 10px;
        overflow: hidden;
        color: #fff;
    }

        .table th, .table td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #333;
        }

        .table th {
            background: #111;
            color: #fff;
        }

        .table tr:hover {
            background: #fff;
        }

    p {
        text-align: center;
        color: #aaa;
    }
</style>

@code {

    Venta venta = new()
    {
        Estado = "Completada"
    };

    List<Cliente> clientes = new();

    List<Venta>? ventas;

    int productoApiId;

    int cantidad = 1;

    decimal precio;

    protected override async Task OnInitializedAsync()
    {
        clientes =
            await Context.Clientes.ToListAsync();

        await CargarVentas();
    }

    private async Task CargarVentas()
    {
        ventas = await Context.Ventas
            .Include(v => v.Cliente)
            .ToListAsync();
    }

    private async Task GuardarVenta()
    {
        venta.Total = cantidad * precio;

        Context.Ventas.Add(venta);

        await Context.SaveChangesAsync();

        var detalle = new DetalleVenta
        {
            VentaId = venta.Id,
            ProductoApiId = productoApiId,
            Cantidad = cantidad,
            Precio = precio
        };

        Context.DetalleVentas.Add(detalle);

        await Context.SaveChangesAsync();

        venta = new Venta
        {
            Estado = "Completada"
        };

        productoApiId = 0;
        cantidad = 1;
        precio = 0;

        await CargarVentas();
    }
}