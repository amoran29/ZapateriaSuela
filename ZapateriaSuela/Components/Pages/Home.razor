@page "/dashboard"
@using Microsoft.EntityFrameworkCore
@using ZapateriaSuela.Data

@inject AppDbContext Context

<PageTitle>Inicio</PageTitle>

<style>

    .dashboard-container {
        min-height: 80vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        padding: 20px;
        color: #ffff;
    }

    .hero-section {
        max-width: 800px;
        margin-bottom: 40px;
    }

    .dashboard-title {
        font-size: 2.5rem;
        font-weight: bold;
        color: #ffff;
    }

    .dashboard-subtitle {
        font-size: 1.2rem;
        color: #fff;
    }

    .stats-container {
        display: flex;
        justify-content: center;
        gap: 20px;
        flex-wrap: wrap;
        width: 100%;
        max-width: 1000px;
    }

    .dashboard-card {
        flex: 1;
        min-width: 220px;
        border-radius: 15px;
        text-align: center;
        background: rgba(255,255,255,0.95);
        border: none;
        transition: transform 0.2s ease;
        color: #111827;
    }

        .dashboard-card:hover {
            transform: translateY(-5px);
        }

        .dashboard-card h1 {
            font-size: 2.2rem;
            font-weight: bold;
            color: #111827;
        }

        .dashboard-card h5 {
            color: #111827; 
            font-weight: 600;
        }

        .dashboard-card p {
            color: #374151; 
        }

    .quick-actions {
        margin-top: 40px;
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
        justify-content: center;
    }

</style>

<div class="dashboard-container">

    <div class="hero-section">

        <h1 class="dashboard-title">
            BIENVENIDO AL SISTEMA DE GESTIÓN DE ZAPATERÍA SUELA
        </h1>

        <p class="dashboard-subtitle">
            Sistema profesional de gestión de clientes y ventas.
        </p>

    </div>

    <div class="stats-container">

        <div class="card shadow-sm p-4 dashboard-card">
            <h5>CLIENTES</h5>
            <h1>@totalClientes</h1>
            <p>Clientes registrados</p>
        </div>

        <div class="card shadow-sm p-4 dashboard-card">
            <h5>VENTAS</h5>
            <h1>@totalVentas</h1>
            <p>Ventas realizadas</p>
        </div>

        <div class="card shadow-sm p-4 dashboard-card">
            <h5> INGRESOS REGISTRADOS</h5>
            <h1>$@totalIngresos</h1>
            <p>Ingreso acumulado</p>
        </div>

    </div>

    <div class="quick-actions">

        <a href="/clientes" class="btn btn-primary">
            Clientes
        </a>

        <a href="/ventas" class="btn btn-success">
            Ventas
        </a>

        <a href="/catalogo" class="btn btn-dark">
            Catálogo
        </a>

    </div>

</div>

@code {

    int totalClientes;
    int totalVentas;
    decimal totalIngresos;

    protected override async Task OnInitializedAsync()
    {
        totalClientes = await Context.Clientes.CountAsync();
        totalVentas = await Context.Ventas.CountAsync();
        totalIngresos = await Context.Ventas.SumAsync(v => (decimal?)v.Total) ?? 0;
    }
}